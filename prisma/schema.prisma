// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NexaMode {
  TEACHER
  STUDENT
}

enum NexaCapability {
  LESSON_PLANNING
  DOUBT_SOLVING
  NOTES_GENERATION
  CONCEPT_TEACHING
  EXAM_TIPS
  CONTENT_CREATION
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum TransactionType {
  SUBSCRIPTION
  CREDIT_PURCHASE
}

enum TransactionStatus {
  CREATED
  PAID
  FAILED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELED
}

/// TeachX Business dashboard partner / tutor applications (teachers on BUSINESS plan)
enum TeachxBizAppType {
  TUTOR_ONE_ON_ONE
  ROOTSCARE_PARTNER
}

enum TeachxBizAppStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExamType {
  MOCK
  PRACTICE
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  password             String
  /// STUDENT | TEACHER — product entry (TeachX vs student app)
  role                 String    @default("STUDENT")
  /// BASIC | PRO | ELITE | TOPRANK
  plan                 String    @default("BASIC")
  /// ACTIVE | INACTIVE
  subscriptionStatus   String    @default("INACTIVE")
  subscriptionExpiry   DateTime?
  trialStartDate       DateTime?
  trialEndsAt          DateTime?
  isTrialActive        Boolean   @default(false)
  credits              Int       @default(0)
  nexaStudentLevel     String?
  nexaStudentSubject   String?
  /// TeachX tier: FREE | PRO | BUSINESS (teachers only; independent of student `plan`)
  teachxPlan           String    @default("FREE")
  teachxCredits        Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  conversations  Conversation[]
  transactions   Transaction[]
  teacherProfile TeacherProfile?
  teacherReviews TeacherReview[]    @relation("teacherReviews")
  studentReviews TeacherReview[]    @relation("studentReviews")
  studentPerformances StudentPerformance[]
  bookingsAsTeacher SessionBooking[] @relation("teacherBookings")
  bookingsAsStudent SessionBooking[] @relation("studentBookings")
  earningLedgers EarningLedger[]
  examAttempts ExamAttempt[]
  courseProgress CourseProgress[]
  certificates Certificate[]
  assessments AssessmentAttempt[]
  careerReports CareerReport[]
  notifications Notification[]
  usageStats UsageStat[]
  teacherStudents TeacherStudent[] @relation("TeacherStudents")
  helpRequestsAsStudent StudentHelpRequest[] @relation("StudentHelpRequests")
  helpRequestsAsTeacher StudentHelpRequest[] @relation("MatchedTeacherHelp")
  top10TrainingState Top10TrainingState?
  topRankVisionBoard TopRankVisionBoard?
  nexaStudentMemory NexaStudentMemory?
  performanceAttemptMetrics PerformanceAttemptMetric[]
  performanceTopicStats PerformanceTopicStat[]
  performanceDailySnapshots PerformanceDailySnapshot[]
  performanceInsightRecords PerformanceInsightRecord[]
  studentProfile StudentProfile?
  questionAttempts Attempt[]
  trainingState    TrainingState?
  teachxBusinessApplications TeachxBusinessApplication[]
}

model TeachxBusinessApplication {
  id        String              @id @default(cuid())
  userId    String
  type      TeachxBizAppType
  status    TeachxBizAppStatus  @default(PENDING)
  /// Form fields (JSON); e.g. tutor profile, pricing, Rootscare interest
  payload   Json
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, createdAt])
}

model StudentProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  exam                String
  targetRank          String
  level               String
  studyHours          Int
  weakness            String
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([exam])
}

/// Per-submitted-attempt analytics (source for progress charts and aggregates).
model PerformanceAttemptMetric {
  id                   String   @id @default(cuid())
  attemptId            String   @unique
  userId               String
  examId               String
  subject              String
  accuracyPct          Float
  timeSpentSec         Int
  questionCount        Int
  secondsPerQuestion   Float
  /// Wrong counts keyed by topicKey (subject|level)
  wrongByTopic         Json     @default("{}")
  rankReadinessSnapshot Int?
  createdAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, subject])
}

/// Rolling topic-level mastery (answered vs correct) for heatmaps and focus tips.
model PerformanceTopicStat {
  id        String   @id @default(cuid())
  userId    String
  topicKey  String
  subject   String
  label     String
  answered  Int      @default(0)
  correct   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicKey])
  @@index([userId, subject])
}

/// Daily aggregates for improvement charts (updated on each attempt).
model PerformanceDailySnapshot {
  id                     String   @id @default(cuid())
  userId                 String
  /// UTC calendar day as YYYY-MM-DD
  dayKey                 String
  avgAccuracy            Float
  attemptCount           Int
  avgSecondsPerQuestion  Float
  /// 0–100: higher = steadier accuracy across attempts that day
  consistencyScore       Float?
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([userId, dayKey])
}

/// Persisted insight lines (rule-based + deltas); shown in performance UI.
model PerformanceInsightRecord {
  id              String   @id @default(cuid())
  userId          String
  message         String
  kind            String
  relatedSubject  String?
  relatedTopic    String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Rolling performance context for Nexa (TOP10 AI Trainer) — updated on exam submit.
model NexaStudentMemory {
  id               String   @id @default(cuid())
  userId           String   @unique
  weakTopics       String[] @default([])
  /// 0–100 estimate of competition readiness from recent exam accuracy.
  rankReadiness    Int      @default(50)
  examCount        Int      @default(0)
  lastAccuracyPct  Float?
  lastExamAt       DateTime?
  /// Last few debrief snapshots: { at, examId, accuracyPct, wrongCount, subject }
  history          Json?
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Plain OTP row for email reset (short-lived). Deleted after successful reset.
model PasswordResetOTP {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("password_reset_otp")
}

model Conversation {
  id         String          @id @default(cuid())
  userId     String
  title      String
  mode       NexaMode
  capability NexaCapability
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  role           ChatMessageRole
  content        String
  createdAt      DateTime        @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  type              TransactionType
  amount            Int
  status            TransactionStatus @default(CREATED)
  plan              String?
  creditsPurchased  Int?
  razorpayOrderId   String?           @unique
  razorpayPaymentId String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TeacherProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  subjects    String[]
  hourlyRate  Int      @default(199)
  avgRating   Float    @default(0)
  totalReviews Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherReview {
  id         String   @id @default(cuid())
  teacherId  String
  studentId  String
  rating     Int
  review     String?
  createdAt  DateTime @default(now())

  teacher User @relation("teacherReviews", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("studentReviews", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId, createdAt])
}

model SessionBooking {
  id         String       @id @default(cuid())
  teacherId  String
  studentId  String
  subject    String
  scheduledAt DateTime
  status     BookingStatus @default(REQUESTED)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  teacher User @relation("teacherBookings", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("studentBookings", fields: [studentId], references: [id], onDelete: Cascade)
}

model EarningLedger {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  source     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentPerformance {
  id         String   @id @default(cuid())
  studentId  String
  /// Catalog exam id, or synthetic key e.g. question-bank:NEET for bank attempts.
  examId     String?
  /// Idempotent tie to ExamAttempt.id or Attempt.id.
  attemptId  String?  @unique
  subject    String
  /// Normalized points or accuracy % (legacy rows may only have this).
  score      Float
  accuracy   Float?
  timeTaken  Int?
  /// 1 = best in peer pool for this exam key at snapshot time.
  rank       Int?
  /// Approx. % of peers at or below this accuracy (0–100).
  percentile Float?
  /// { weakTopics: string[], speedIssues: string[], accuracyProblems: string[] }
  analysis   Json     @default("{}")
  weakAreas  String[]
  createdAt  DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([examId, createdAt])
}

model QuestionBank {
  id          String   @id @default(cuid())
  subject     String
  level       String
  question    String
  options     String[]
  answer      String
  explanation String?
  createdAt   DateTime @default(now())
}

/// Structured bank item for TopRank exam engine (MCQ with metadata).
model Question {
  id            String   @id @default(cuid())
  exam          String
  subject       String
  topic         String
  subtopic      String
  difficulty    String
  type          String
  questionText  String
  options       Json
  correctAnswer String
  explanation   String
  expectedTime  Int
  marks         Int
  negativeMarks Int
  createdAt     DateTime @default(now())

  attemptItems AttemptQuestion[]

  @@index([exam, subject])
  @@index([topic])
  @@index([difficulty])
}

/// Graded exam session against `Question` bank (distinct from legacy `ExamAttempt`).
model Attempt {
  id             String    @id @default(cuid())
  userId         String
  exam           String
  subject        String
  mode           String
  questionIds    String[]
  score          Int       @default(0)
  total          Int
  accuracy       Float     @default(0)
  timeTaken      Int       @default(0)
  allowedSeconds Int?
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items AttemptQuestion[]

  @@index([userId, createdAt])
}

model AttemptQuestion {
  id         String  @id @default(cuid())
  attemptId  String
  questionId String
  selected   String
  isCorrect  Boolean

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model Exam {
  id          String    @id @default(cuid())
  title       String
  subject     String
  durationMin Int
  type        ExamType  @default(MOCK)
  createdAt   DateTime  @default(now())
  attempts    ExamAttempt[]
}

model ExamAttempt {
  id          String   @id @default(cuid())
  examId      String
  userId      String
  score       Float    @default(0)
  maxScore    Float    @default(0)
  startedAt   DateTime @default(now())
  submittedAt DateTime?
  /// PRACTICE | ADVANCED | TOP10 when started from training modes
  trainingMode String?
  surpriseReal Boolean @default(false)
  dailyChallenge Boolean @default(false)
  /// When set, submit timer uses this instead of exam.durationMin (e.g. surprise simulation).
  allowedSeconds Int?

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// TopRank (TOP10) — dream rank entry, vision board, environment checklist.
model TopRankVisionBoard {
  id               String   @id @default(cuid())
  userId           String   @unique
  /// e.g. NEET, JEE_MAIN, JEE_ADV, CUET, STATE_PMT, OTHER
  examTrack        String
  targetRank       Int
  targetDate       DateTime
  /// Auto-derived from rank band + exam (display on vision board).
  dreamCollege     String
  /// Short goal line, e.g. "AIR 1500 · NEET · Jun 2026"
  goalCardLine     String
  envStudyTable       Boolean @default(false)
  envDistractionFree  Boolean @default(false)
  envDailySchedule    Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// TopRank conditioning loop — topic memory + difficulty (exam engine integration).
model TrainingState {
  id           String   @id @default(cuid())
  userId       String   @unique
  level        String   @default("Average")
  intensity    String   @default("Medium")
  weakTopics   Json     @default("[]")
  strongTopics Json     @default("[]")
  lastScore    Int?
  lastAccuracy Float?
  lastExam     String?
  lastSubject  String?
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Persistent TOP10 Rank Training loop (exam → analysis → practice → re-test).
model Top10TrainingState {
  id                   String    @id @default(cuid())
  userId               String    @unique
  /// IDLE | EXAM | RESULT | ANALYSIS | PRACTICE | RETRY
  phase                String    @default("IDLE")
  difficulty           Int       @default(2)
  weakTopics           String[]  @default([])
  circuitCount         Int       @default(0)
  streakPasses         Int       @default(0)
  lastAttemptId        String?
  lastExamId           String?
  pendingRetry         Boolean   @default(false)
  lastWrongQuestionIds String[]  @default([])
  lastAccuracyPct      Float?
  /// UTC day start when daily challenge was last assigned
  dailyChallengeDate   DateTime?
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id         String   @id @default(cuid())
  title      String
  category   String
  description String
  videoUrl   String?
  createdAt  DateTime @default(now())
  lessons    Lesson[]
  progress   CourseProgress[]
}

model Lesson {
  id         String   @id @default(cuid())
  courseId   String
  title      String
  videoUrl   String
  createdAt  DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseProgress {
  id          String   @id @default(cuid())
  courseId    String
  userId      String
  progressPct Float    @default(0)
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Certificate {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  issuedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model AssessmentAttempt {
  id         String   @id @default(cuid())
  userId     String
  answers    Json
  score      Float
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareerReport {
  id                 String   @id @default(cuid())
  userId             String
  strengths          String[]
  careerSuggestions  String[]
  summary            String
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UsageStat {
  id         String   @id @default(cuid())
  userId     String
  day        DateTime
  aiRequests Int      @default(0)
  /// Cumulative prompt tokens (OpenAI) for this UTC day — cost control + monitoring.
  aiTokensPrompt     Int @default(0)
  /// Cumulative completion tokens for this UTC day.
  aiTokensCompletion Int @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, day])
}

model TeacherStudent {
  id        String   @id @default(cuid())
  teacherId String
  name      String
  email     String?
  grade     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher User @relation("TeacherStudents", fields: [teacherId], references: [id], onDelete: Cascade)
  attendances AttendanceRecord[]
  marks       MarkEntry[]

  @@index([teacherId])
}

model AttendanceRecord {
  id               String   @id @default(cuid())
  teacherStudentId String
  date             DateTime
  present          Boolean  @default(true)

  teacherStudent TeacherStudent @relation(fields: [teacherStudentId], references: [id], onDelete: Cascade)

  @@unique([teacherStudentId, date])
}

model MarkEntry {
  id               String   @id @default(cuid())
  teacherStudentId String
  subject          String
  title            String?
  score            Float
  maxScore         Float
  term             String?
  createdAt        DateTime @default(now())

  teacherStudent TeacherStudent @relation(fields: [teacherStudentId], references: [id], onDelete: Cascade)

  @@index([teacherStudentId, createdAt])
}

model StudentHelpRequest {
  id                 String   @id @default(cuid())
  studentId          String
  topic              String
  subject            String?
  status             String   @default("OPEN")
  matchedTeacherId   String?
  createdAt          DateTime @default(now())

  student User @relation("StudentHelpRequests", fields: [studentId], references: [id], onDelete: Cascade)
  matchedTeacher User? @relation("MatchedTeacherHelp", fields: [matchedTeacherId], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
}
